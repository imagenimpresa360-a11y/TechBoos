	<script>
	(function(){
		if (window.FC_Carousel && typeof window.FC_Carousel.create === 'function') return;

		var instances = {};

		function toEl(v) {
			if (!v) return null;
			if (typeof v === 'string') return document.querySelector(v);
			return v;
		}
		function toEls(v) {
			if (!v) return [];
			if (typeof v === 'string') return Array.prototype.slice.call(document.querySelectorAll(v));
			if (Array.isArray(v)) return v;
			if (v instanceof NodeList) return Array.prototype.slice.call(v);
			return [];
		}
		function getPerPage(perPage){
			try {
				return (typeof perPage === 'function') ? parseInt(perPage(), 10) : parseInt(perPage, 10);
			} catch(_){ }
			return 5;
		}
		function clamp(n, min, max){ return Math.max(min, Math.min(max, n)); }
		function setFading(el, on){ try { if (el) el.classList.toggle('is-fading', !!on); } catch(_){ } }
		function setText(el, txt){ try { if (el) el.textContent = txt; } catch(_){ } }
		function setDisabled(btn, disabled){
			try {
				if (!btn) return;
				btn.disabled = !!disabled;
				if (disabled) btn.setAttribute('disabled','disabled'); else btn.removeAttribute('disabled');
			} catch(_){ }
		}

		function create(opts){
			opts = opts || {};
			var key = String(opts.key || opts.name || ('carousel_' + Math.random()));
			var state = { page: 0 };
			var containerEl = toEl(opts.container);
			if (containerEl && !containerEl.classList.contains('fc-carousel')) {
				try { containerEl.classList.add('fc-carousel'); } catch(_){ }
			}
			var controls = opts.controls || {};
			var ctrWrap = toEl(controls.wrapper);
			var btnPrev = toEl(controls.prevBtn);
			var btnNext = toEl(controls.nextBtn);
			var labelEl = toEl(controls.labelEl);
			var animate = (typeof opts.animate === 'boolean') ? opts.animate : true;
			var scrollToTop = (typeof opts.scrollToTop === 'boolean') ? opts.scrollToTop : false;
			var isVirtual = !!(opts && typeof opts.renderPage === 'function');

			function getItems(){
				try {
					if (typeof opts.getItems === 'function') return (opts.getItems() || []).slice();
				} catch(_){ }
				return toEls(opts.items);
			}
			function isVisible(el){
				try {
					if (typeof opts.isVisible === 'function') return !!opts.isVisible(el);
				} catch(_){ }
				return true;
			}
			function getVisibleItems(){
				var all = getItems();
				return all.filter(isVisible);
			}
			function hideAll(all){
				for (var i = 0; i < all.length; i++) { all[i].style.display = 'none'; }
			}
			function showSlice(vis, start, end){
				for (var i = 0; i < vis.length; i++) { vis[i].style.display = (i >= start && i < end) ? '' : 'none'; }
			}
			function syncControls(total){
				var per = getPerPage(opts.perPage);
				if (!per || per < 1) per = 1;
				var totalPages = Math.max(1, Math.ceil(total / per));
				state.page = clamp(state.page, 0, totalPages - 1);
				if (ctrWrap) {
					ctrWrap.style.display = (total > per) ? 'flex' : 'none';
				}
				setDisabled(btnPrev, state.page <= 0);
				setDisabled(btnNext, state.page >= totalPages - 1);
				if (labelEl) {
					setText(labelEl, 'Página ' + (total ? (state.page + 1) : 0) + ' / ' + (total ? totalPages : 0));
				}
			}
			function render(forceNoAnim){
				var per = getPerPage(opts.perPage);
				if (!per || per < 1) per = 1;
				var all = getItems();
				var vis = getVisibleItems();
				var total = isVirtual ? (function(){
					try {
						if (typeof opts.getTotal === 'function') return parseInt(opts.getTotal(), 10) || 0;
					} catch(_){ }
					return (Array.isArray(all) ? all.length : 0);
				})() : vis.length;
				var totalPages = Math.max(1, Math.ceil(total / per));
				state.page = clamp(state.page, 0, totalPages - 1);
				var start = state.page * per;
				var end = start + per;

				function apply(){
					if (isVirtual) {
						try {
							var slice = [];
							if (Array.isArray(all)) { slice = all.slice(start, Math.min(end, total)); }
							opts.renderPage({
								page: state.page,
								per: per,
								total: total,
								totalPages: totalPages,
								start: start,
								end: Math.min(end, total),
								slice: slice,
								all: all
							});
						} catch(_){ }
					} else {
						hideAll(all);
						showSlice(vis, start, end);
					}
					syncControls(total);
					try { if (typeof opts.onRender === 'function') opts.onRender({ page: state.page, per: per, total: total, totalPages: totalPages }); } catch(_){ }
					if (scrollToTop) {
						try {
							var top = containerEl ? containerEl.getBoundingClientRect().top + (window.pageYOffset || 0) - 10 : 0;
							window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
						} catch(_){ }
					}
				}

				if (forceNoAnim || !animate || !containerEl) {
					apply();
					return;
				}
				setFading(containerEl, true);
				setTimeout(function(){
					apply();
					setFading(containerEl, false);
				}, 160);
			}

			var api = {
				key: key,
				render: function(forceNoAnim){ render(!!forceNoAnim); },
				next: function(){ state.page = state.page + 1; render(false); },
				prev: function(){ state.page = Math.max(0, state.page - 1); render(false); },
				setPage: function(p){ state.page = parseInt(p, 10) || 0; render(false); },
				reset: function(){ state.page = 0; render(true); },
				refresh: function(forceNoAnim){ render(!!forceNoAnim); },
				getPage: function(){ return state.page; },
			};
			instances[key] = api;
			return api;
		}

		window.FC_Carousel = {
			create: create,
			get: function(key){ return instances[String(key || '')] || null; },
			_refreshAll: function(){
				try {
					Object.keys(instances).forEach(function(k){
						try { instances[k].refresh(true); } catch(_){ }
					});
				} catch(_){ }
			}
		};
	})();
