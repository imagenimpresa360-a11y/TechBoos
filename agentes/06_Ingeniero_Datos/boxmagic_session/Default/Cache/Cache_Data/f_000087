<script>
$(function(){
  // Nota: la lógica de disponibilidad se cruza con agrupaciones.
  // - Si el alumno tiene agrupaciones, NO mostramos "Ver disponibilidad".
  // - Si el alumno NO tiene agrupaciones, NO mostramos la opción de agrupaciones.
  // La visibilidad se controla en refreshGroupsCardVisibility() según state.groups.
});

// Agrupaciones del alumno (reemplaza plantillas)
$(function(){
  var state = {
    loadedForMensualidadId: null,
    groups: [],
    selectedGroupId: null
  };

  function refreshGroupsCardVisibility(){
    try {
      var mensualidadId = $('#mensualidad_id').val();
      var $wrap = $('#student-groups-card-wrapper');
      var $btnDisp = $('#revisar-disponibilidad');
      if (!$wrap.length) return;

      // Regla estricta: sin mensualidad seleccionada, nunca mostramos agrupaciones
      // y tampoco mostramos disponibilidad (depende de la mensualidad/plan).
      if (!mensualidadId) {
        state.groups = [];
        state.loadedForMensualidadId = null;
        setSelectedGroup(null);
        $('#ejecutar_agrupacion').prop('checked', false);
        $('#student-groups-names').html('<span class="text-muted">—</span>');
        $wrap.hide();
        if ($btnDisp.length) $btnDisp.hide();
        return;
      }

      // Regla simple (mutuamente excluyentes):
      // - Si hay agrupaciones activas => mostrar card y ocultar disponibilidad
      // - Si NO hay agrupaciones => ocultar card y mostrar disponibilidad
      if (Array.isArray(state.groups) && state.groups.length > 0) {
        $wrap.show();
        if ($btnDisp.length) $btnDisp.hide();
      } else {
        $wrap.hide();
        $('#ejecutar_agrupacion').prop('checked', false);
        setSelectedGroup(null);
        if ($btnDisp.length) $btnDisp.show();
      }
    } catch(e) { /* noop */ }
  }

  // Watcher: en este modal hay flujos donde mensualidad_id se setea programáticamente
  // sin disparar el evento change. Observamos mientras el modal está abierto.
  var __groupsWatchTimer = null;
  function startGroupsWatcher(){
    try {
      if (__groupsWatchTimer) return;
      __groupsWatchTimer = setInterval(function(){
        try {
          refreshGroupsCardVisibility();
          var mid = $('#mensualidad_id').val();
          if (mid && String(state.loadedForMensualidadId || '') !== String(mid)) {
            state.loadedForMensualidadId = null;
            ensureGroupsLoaded();
          }
        } catch(_) { /* noop */ }
      }, 500);
    } catch(_) { /* noop */ }
  }
  function stopGroupsWatcher(){
    try {
      if (__groupsWatchTimer) {
        clearInterval(__groupsWatchTimer);
        __groupsWatchTimer = null;
      }
    } catch(_) { /* noop */ }
  }

  function normalizeGroups(items){
    if (!Array.isArray(items)) return [];
    return items.map(function(it){
      // Si el backend trae agrupaciones inactivas, las ignoramos.
      try {
        var hasActive = (it && (Object.prototype.hasOwnProperty.call(it,'is_active') || Object.prototype.hasOwnProperty.call(it,'active') || Object.prototype.hasOwnProperty.call(it,'activo')));
        if (hasActive) {
          var av = (it.is_active != null) ? it.is_active : ((it.active != null) ? it.active : it.activo);
          if (!(av === true || av === 1 || av === '1' || av === 'true')) {
            return null;
          }
        }
      } catch(_){ }
      var id = it && (it.id || it.group_id) ? parseInt(it.id || it.group_id, 10) : 0;
      var name = it && (it.name || it.nombre) ? (it.name || it.nombre) : 'Agrupación';
      var dc = Array.isArray(it && it.dias_clases_ids) ? it.dias_clases_ids : [];
      dc = dc.map(function(v){ return parseInt(v, 10); }).filter(function(v){ return v > 0; });
      return { id: id, name: name, dias_clases_ids: dc };
    }).filter(function(g){ return (g && g.id > 0); });
  }

  function renderGroupsNames(){
    var $host = $('#student-groups-names');
    if (!$host.length) return;

    if (!state.groups.length) {
      $host.html('<span class="text-muted">—</span>');
      return;
    }

    var html = state.groups.map(function(g){
      return '<div class="sg-group-name">' + String(g.name || '').replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</div>';
    }).join('');
    $host.html(html);
  }

  function setSelectedGroup(groupId){
    var gid = parseInt(groupId || 0, 10);
    state.selectedGroupId = gid > 0 ? gid : null;
    var group = state.groups.filter(function(g){ return g.id === state.selectedGroupId; })[0] || null;

    // IMPORTANTE: solo enviar selección al backend si el usuario activó la creación automática.
    // Esto evita que una autoselección (p.ej. cuando hay 1 agrupación) cree reservas sin que el usuario lo haya pedido.
    var execute = false;
    try { execute = ($('#ejecutar_agrupacion').length && $('#ejecutar_agrupacion').is(':checked')); } catch(_){ execute = false; }
    $('#fixed_group_id_selected').val(execute && state.selectedGroupId ? String(state.selectedGroupId) : '');
  }

  function ensureGroupsLoaded(){
    return new Promise(function(resolve){
      try {
        refreshGroupsCardVisibility();
        var mensualidadId = $('#mensualidad_id').val();
        if (!mensualidadId) {
          // Sin mensualidad: no se puede cargar agrupaciones
          resolve({ ok: false, groups: [] });
          return;
        }
        if (state.loadedForMensualidadId && String(state.loadedForMensualidadId) === String(mensualidadId)) {
          renderGroupsNames();
          resolve({ ok: true, groups: state.groups.slice() });
          return;
        }

        $.ajax({
          url: '/mensualidad/agrupaciones-usuario',
          method: 'POST',
          headers: { 'X-CSRF-Token': 'xBKgWebTph6gA2O7vdmowPzV2tfZI6iPA47BpW69' },
          data: { mensualidad_id: mensualidadId }
        }).done(function(resp){
          if (!resp || resp.ok !== true) {
            state.groups = [];
            state.loadedForMensualidadId = mensualidadId;
            setSelectedGroup(null);
            renderGroupsNames();
            try { refreshGroupsCardVisibility(); } catch(_){ }
            resolve({ ok: false, groups: [] });
            return;
          }
          state.groups = normalizeGroups(resp.items || []);
          state.loadedForMensualidadId = mensualidadId;

          // Autoselección si solo hay 1
          if (state.groups.length === 1) {
            setSelectedGroup(state.groups[0].id);
          } else {
            setSelectedGroup(null);
          }
          renderGroupsNames();
          try { refreshGroupsCardVisibility(); } catch(_){ }
          resolve({ ok: true, groups: state.groups.slice() });
        }).fail(function(){
          state.groups = [];
          state.loadedForMensualidadId = mensualidadId;
          setSelectedGroup(null);
          renderGroupsNames();
          try { refreshGroupsCardVisibility(); } catch(_){ }
          resolve({ ok: false, groups: [] });
        });
      } catch(e) {
        resolve({ ok: false, groups: [] });
      }
    });
  }

  function chooseGroupIfNeeded(reason){
    return new Promise(function(resolve){
      ensureGroupsLoaded().then(function(){
        if (!state.groups.length) {
          resolve({ ok: false });
          return;
        }
        if (state.groups.length === 1) {
          setSelectedGroup(state.groups[0].id);
          resolve({ ok: true, group: state.groups[0] });
          return;
        }

        if (window.Swal && typeof window.Swal.fire === 'function') {
          var options = {};
          state.groups.forEach(function(g){ options[String(g.id)] = g.name; });
          window.Swal.fire({
            title: 'Selecciona una agrupación',
            text: (reason === 'schedule') ? 'El alumno tiene más de una agrupación. Elige cuál horario quieres ver.' : 'El alumno tiene más de una agrupación. Elige cuál usar para crear reservas.',
            type: 'question',
            input: 'select',
            inputOptions: options,
            inputPlaceholder: 'Selecciona una opción',
            showCancelButton: true,
            confirmButtonText: 'Seleccionar',
            cancelButtonText: 'Cancelar'
          }).then(function(res){
            if (res && (res.isConfirmed || res.value)) {
              var gid = parseInt(res.value, 10) || 0;
              if (gid > 0) {
                setSelectedGroup(gid);
                var gr = state.groups.filter(function(g){ return g.id === gid; })[0] || null;
                resolve({ ok: true, group: gr });
                return;
              }
            }
            resolve({ ok: false });
          });
          return;
        }

        var msg = 'El alumno tiene más de una agrupación. Selecciona una ID:\n\n' + state.groups.map(function(g){ return g.id + ' - ' + g.name; }).join('\n');
        var raw = window.prompt(msg, String(state.groups[0].id));
        var gid = parseInt(raw, 10) || 0;
        if (gid > 0) {
          setSelectedGroup(gid);
          var gr2 = state.groups.filter(function(g){ return g.id === gid; })[0] || null;
          resolve({ ok: true, group: gr2 });
          return;
        }
        resolve({ ok: false });
      });
    });
  }

  // Cuando se intenta crear reservas automáticamente, elegir agrupación si hay más de una
  $('#ejecutar_agrupacion').on('change', function(){
    try {
      var checked = $('#ejecutar_agrupacion').is(':checked');
      if (!checked) {
        setSelectedGroup(null);
        return;
      }

      if (!$('#mensualidad_id').val()) {
        if (window.Swal && typeof window.Swal.fire === 'function') {
          window.Swal.fire('Falta información', 'Primero selecciona un cliente y un plan.', 'warning');
        }
        $('#ejecutar_agrupacion').prop('checked', false);
        setSelectedGroup(null);
        refreshGroupsCardVisibility();
        return;
      }

      chooseGroupIfNeeded('auto').then(function(r){
        if (!r || r.ok !== true) {
          $('#ejecutar_agrupacion').prop('checked', false);
          setSelectedGroup(null);
        }
      });
    } catch(_){ }
  });

  // Ver horario de agrupación
  $('#view-student-group-schedule-btn').on('click', function(){
    try {
      if (!$('#mensualidad_id').val()) {
        if (window.Swal && typeof window.Swal.fire === 'function') {
          window.Swal.fire('Falta información', 'Primero selecciona un cliente y un plan.', 'warning');
        }
        refreshGroupsCardVisibility();
        return;
      }

      function hexToRgba(hex, alpha) {
        if (!hex) return 'rgba(0,0,0,' + (alpha || 0.15) + ')';
        hex = String(hex).replace('#','');
        if (hex.length === 3) hex = hex.split('').map(function(c){ return c + c; }).join('');
        var r = parseInt(hex.substring(0,2), 16);
        var g = parseInt(hex.substring(2,4), 16);
        var b = parseInt(hex.substring(4,6), 16);
        var a = (typeof alpha === 'number') ? alpha : 0.15;
        return 'rgba(' + r + ',' + g + ',' + b + ',' + a + ')';
      }
      function formatTime(hhmm) {
        if (!hhmm || typeof hhmm !== 'string') return '--:--';
        var parts = hhmm.split(':');
        if (parts.length < 2) return hhmm;
        var h = parseInt(parts[0], 10);
        var m = parts[1];
        if (isNaN(h)) return hhmm;
        var suffix = h >= 12 ? 'pm' : 'am';
        var h12 = h % 12; if (h12 === 0) h12 = 12;
        return h12 + ':' + m + ' ' + suffix;
      }
      function buildScheduleHtml(groupName, data) {
        var dayNames = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
        var monthNames = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
        var ref = new Date();
        if (data && data.week_start) { try { ref = new Date(data.week_start + 'T00:00:00'); } catch(e) {} }
        var day = ref.getDay();
        var offsetToMonday = (day + 6) % 7;
        var monday = new Date(ref); monday.setDate(ref.getDate() - offsetToMonday);
        var sunday = new Date(monday); sunday.setDate(monday.getDate() + 6);
        var mondayLabel = dayNames[1] + ' ' + monday.getDate();
        var sundayLabel = dayNames[0] + ' ' + sunday.getDate();
        var monthLabel = monthNames[sunday.getMonth()];

        var genMode = (data && data.reservation_generation_mode) ? String(data.reservation_generation_mode) : 'payment_period';
        if (genMode !== 'payment_period' && genMode !== 'rolling_weeks') { genMode = 'payment_period'; }
        var genWeeks = 0;
        try { genWeeks = (data && data.reservation_horizon_weeks != null) ? parseInt(data.reservation_horizon_weeks, 10) : 0; } catch(_){ genWeeks = 0; }
        if (isNaN(genWeeks) || genWeeks < 0) { genWeeks = 0; }
        if (genWeeks > 52) { genWeeks = 52; }
        var genLabel = '';
        if (genMode === 'rolling_weeks') {
          var xWeeks = Math.max(1, genWeeks);
          genLabel = 'Hasta ' + xWeeks + ' semanas de clases desde la fecha vigente del plan.';
        } else {
          genLabel = 'Hasta el fin del pago del alumno.';
        }

        var scheduleCss = ''
          + '<style>'
          + ' .fc-schedule-wrap{font-family:inherit;}'
          + ' .week-days-grid{display:flex;flex-wrap:wrap;margin-left:-8px;margin-right:-8px;}'
          + ' .week-days-grid .day-col{flex:0 0 14.2857%;max-width:14.2857%;padding-left:8px;padding-right:8px;}'
          + ' @media (max-width: 991.98px){.week-days-grid .day-col{flex:0 0 33.3333%;max-width:33.3333%;}}'
          + ' @media (max-width: 575.98px){.week-days-grid .day-col{flex:0 0 50%;max-width:50%;}}'
          + ' .day-card-title{text-align:center;font-weight:800;letter-spacing:.3px;}'
          + ' .class-item{position:relative;border-left:4px solid transparent;border-radius:12px;background:#fff;}'
          + ' .time-badge{display:inline-block;padding:.25rem .5rem;border-radius:.5rem;font-weight:800;font-size:.85rem;}'
          + ' .class-name{color:#111827;font-weight:800;font-size:14px;line-height:1.15;}'
          + ' .schedule-info-box{background:#eff6ff;border:1px solid #dbeafe;border-radius:12px;padding:12px 14px;display:flex;gap:12px;align-items:flex-start;}'
          + ' .schedule-info-icon{width:34px;height:34px;border-radius:9999px;background:#5d67e8;color:#fff;display:flex;align-items:center;justify-content:center;flex:0 0 auto;}'
          + '</style>';

        var header = ''+
          '<div style="text-align:left;">'
            + '<div style="display:flex;align-items:center;gap:10px;">'
              + '<div style="width:34px;height:34px;border-radius:10px;border:1px solid rgba(101,110,232,0.35);background:transparent;display:flex;align-items:center;justify-content:center;">'
                + '<i class="fas fa-clock" style="color:#656ee8;"></i>'
              + '</div>'
              + '<div style="font-weight:800;color:#111827;">Horario de la agrupación</div>'
            + '</div>'
            + '<div style="margin-top:6px;color:#6b7280;">' + String(groupName||'').replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</div>'
            + '<div style="margin-top:10px; padding:10px 12px; border:1px solid #dbeafe; background:#eff6ff; border-radius:12px;">'
              + '<div style="font-weight:800;color:#111827; margin-bottom:2px;">Generación de reservas</div>'
              + '<div style="font-weight:700;color:#111827;">' + String(genLabel).replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</div>'
              + '<div style="color:#6b7280; font-size:12px; margin-top:4px;">Si el plan ya comenzó, se consideran semanas desde hoy.</div>'
              + '<div style="color:#6b7280; font-size:12px;">Si aún no inicia, desde su fecha de inicio.</div>'
              + '<div style="color:#6b7280; font-size:12px;">Siempre limitado por la fecha de fin del pago del alumno.</div>'
            + '</div>'
            + '<div style="margin-top:12px;color:#111827;display:flex;align-items:center;gap:8px;">'
              + '<i class="far fa-calendar-alt" style="color:#656ee8;"></i>'
              + '<div style="font-weight:700;">Semana del ' + mondayLabel + ' al ' + sundayLabel + ' de <span style="color:#581c87;font-weight:800;">' + monthLabel + '</span></div>'
            + '</div>'
          '</div>';

        var shortNames = ['DOM','LUN','MAR','MIE','JUE','VIE','SAB'];
        var palette = ['#a754f7', '#22c55e', '#f59e0b', '#ef4444', '#06b6d4', '#9333ea', '#f97316'];
        var daysHtml = '<div class="mt-3 week-days-grid">';
        for (var i = 0; i < 7; i++) {
          var d = new Date(monday); d.setDate(monday.getDate() + i);
          var label = shortNames[d.getDay()] + ' ' + d.getDate();
          var dayClasses = [];
          if (data && Array.isArray(data.days) && Array.isArray(data.days[i])) dayClasses = data.days[i];

          var dayInner = '';
          for (var j = 0; j < dayClasses.length; j++) {
            var cls = dayClasses[j] || {};
            var color = cls.color || palette[(i + j) % palette.length];
            var timeStart = formatTime(cls.hora_inicio || '07:00');
            var timeEnd = formatTime(cls.hora_fin || '08:00');
            var className = cls.name || ('Clase ' + (j+1));
            var coachName = (cls.coach_name != null && String(cls.coach_name).trim() !== '') ? String(cls.coach_name) : 'Sin profesor';

            var subtle = hexToRgba(color, 0.12);
            var borderStyle = 'border-left-color: ' + color + ';'
                            + ' border-top: 1px solid ' + subtle + ';'
                            + ' border-right: 1px solid ' + subtle + ';'
                            + ' border-bottom: 1px solid ' + subtle + ';';
            var badgeBg = hexToRgba(color, 0.15);
            var badgeStyle = 'background-color: ' + badgeBg + '; color: ' + color + ';';

            dayInner += ''+
              '<div class="class-item p-2 mb-2" style="' + borderStyle + '">' +
                '<div class="mb-1"><span class="time-badge" style="' + badgeStyle + '">' + timeStart + ' - ' + timeEnd + '</span></div>' +
                '<div class="class-name h5 mb-1">' + String(className).replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</div>' +
                '<div class="small text-muted">' +
                  '<i class="fas fa-user mr-1" aria-hidden="true"></i>' +
                  String(coachName).replace(/</g,'&lt;').replace(/>/g,'&gt;') +
                '</div>' +
              '</div>';
          }

          daysHtml += ''+
            '<div class="day-col mb-3">'
              + '<div class="border rounded p-3 h-100">'
